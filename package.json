{
  "name": "zolto",
  "version": "3.0.0",
  "description": "Zolto — Extended Markdown document engine. Phase 2: production-quality Markdown superset.",
  "type": "module",
  "main": "src/zolto.js",
  "exports": {
    ".":             "./src/zolto.js",
    "./ast":         "./src/ast.js",
    "./diagnostics": "./src/diagnostics.js",
    "./renderer":    "./src/renderer.js",
    "./lexer":       "./src/lexer.js",
    "./parser":      "./src/parser.js",
    "./inline":      "./src/inline-parser.js",
    "./validator":   "./src/validator.js",
    "./tokenizer":   "./src/tokenizer.js"
  },
  "scripts": {
    "dev":    "npx serve . --port 3000 --no-request-logging",
    "test":   "node --input-type=module < tests/run-all.js",
    "test:node": "node tests/run-all.js",
    "lint":   "npx eslint src/ tests/ --ext .js",
    "format": "npx prettier --write src/ tests/ *.md",
    "build":  "echo 'No build step required — ES modules run natively'",
    "check":  "node --check src/*.js tests/*.js"
  },
  "engines": { "node": ">=20.0.0" },
  "keywords": [
    "markdown", "extended-markdown", "document-engine",
    "parser", "renderer", "callouts", "admonitions",
    "reference-links", "definition-lists", "zolto"
  ],
  "author": "Zolto Team",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^10.7.0",
    "prettier": "^3.0.0",
    "serve": "^14.0.0"
  }
}
