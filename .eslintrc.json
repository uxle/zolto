{
  "env":     { "es2022": true, "browser": true, "node": true },
  "globals": { "performance": "readonly" },
  "parserOptions": { "ecmaVersion": 2022, "sourceType": "module" },
  "rules": {
    "no-var":              "error",
    "prefer-const":        "warn",
    "eqeqeq":             ["error", "always"],
    "no-unused-vars":      ["warn", { "argsIgnorePattern": "^_" }],
    "no-console":          "off",
    "semi":                ["error", "always"]
  }
}
