{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "allowJs":          true,
    "checkJs":          false,
    "strict":           false,
    "noEmit":           true,
    "skipLibCheck":     true
  },
  "include": ["src/**/*.js", "tests/**/*.js", "js/**/*.js"]
}
