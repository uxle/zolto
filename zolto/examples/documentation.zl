@var lib      = zolto-parser
@var version  = 8.1.0
@var pkg      = @zolto/parser

# {lib} · API Reference · v{version}

The `{lib}` package is the standalone Zolto parse pipeline. It exposes
the full tokenizer → lexer → parser → transformer → validator chain
as a single importable module.

```bash
npm install {pkg}
```

---

## Quick Start

```javascript
import { parse, transform, validate } from '{pkg}';

const source = `
# Hello

<tip>This is a tip.</tip>

The answer is <m>42</m>.
`;

const ast    = parse(source);
const valid  = validate(ast);
const result = transform(ast);

console.log(result.nodes);
```

<tip>
The three functions are composable but also available as a single
`pipeline(source, options?)` call that runs all three steps.
</tip>

---

## API Reference

<tabs>
  <tab title="parse()">

### `parse(source, options?)`

Tokenizes and parses a Zolto source string into a raw AST.

```typescript
function parse(
  source:  string,
  options?: ParseOptions
): ZoltoAST

interface ParseOptions {
  filename?:      string;       // Used in error messages
  tabWidth?:      number;       // Default: 2
  strict?:        boolean;      // Default: false
  extensions?:    Extension[];  // Parser extensions
}
```

**Returns:** `ZoltoAST` — root `DocumentNode` with `children`, `meta`, and
`diagnostics` arrays.

**Throws:** Never. Parse errors are added to `ast.diagnostics` with severity
`'error'`, `'warning'`, or `'hint'`.

**Example:**

```javascript
const ast = parse('# Hello\n\n<tip>Great!</tip>');
console.log(ast.children.length);      // 2
console.log(ast.children[0].type);     // 'heading'
console.log(ast.children[1].type);     // 'callout'
console.log(ast.children[1].attrs.variant); // 'tip'
```

  </tab>
  <tab title="validate()">

### `validate(ast, options?)`

Runs the semantic validator over a parsed AST. Adds diagnostics for
unknown tags, missing required props, unclosed tags, etc.

```typescript
function validate(
  ast:      ZoltoAST,
  options?: ValidateOptions
): ValidationResult

interface ValidateOptions {
  components?: ComponentDef[];   // Known external components
  strict?:     boolean;          // Treat warnings as errors
}

interface ValidationResult {
  valid:       boolean;
  errors:      Diagnostic[];
  warnings:    Diagnostic[];
  hints:       Diagnostic[];
}
```

**Example:**

```javascript
const { valid, errors, warnings } = validate(ast);
if (!valid) {
  errors.forEach(e => console.error(e.message, e.range));
}
```

  </tab>
  <tab title="transform()">

### `transform(ast, options?)`

Runs the 8-pass transformer pipeline over the AST:

1. Variable extraction (`@var` declarations)
2. Variable expansion (`{name}` references)
3. Component registration (`<component>` definitions)
4. Inline parsing (converts text nodes to inline AST)
5. Math AST building (KaTeX expression trees)
6. Equation numbering (assigns `number` to `<math number>` nodes)
7. Footnote resolution (collects and renumbers `[^ref]`)
8. Heading anchor deduplication

```typescript
function transform(
  ast:      ZoltoAST,
  options?: TransformOptions
): ZoltoAST   // mutates in-place and returns

interface TransformOptions {
  variables?:   Record<string, string>;  // Initial variable values
  components?:  ComponentDef[];          // Pre-registered components
  mathEngine?:  'katex' | 'mathjax' | 'auto';  // Default: 'auto'
}
```

  </tab>
  <tab title="pipeline()">

### `pipeline(source, options?)`

Convenience wrapper that runs `parse → validate → transform` in sequence.

```typescript
function pipeline(
  source:  string,
  options?: PipelineOptions
): PipelineResult

interface PipelineResult {
  ast:         ZoltoAST;
  valid:       boolean;
  diagnostics: Diagnostic[];
  variables:   Record<string, string>;
  components:  ComponentDef[];
}
```

**Example:**

```javascript
const { ast, valid, diagnostics } = pipeline(source, {
  variables: { version: '8.1.0' },
  strict:    false,
});

if (!valid) {
  diagnostics.filter(d => d.severity === 'error')
             .forEach(d => console.error(d.message));
}
```

  </tab>
</tabs>

